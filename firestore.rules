rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    // User Validation Blueprint
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid
        && data.balance is number && data.balance >= 0
        && data.createdAt is string && data.createdAt.size() <= 64;
    }

    // --- Collections ---

    match /products/{id} {
      allow read, write: if true;
    }

    match /categories/{id} {
      allow read, write: if true;
    }

    // Users Collection
    match /users/{userId} {
      // Security: Only the owner can read their own profile
      allow get: if isOwner(userId);
      // Query Enforcer: Deny blanket listing
      allow list: if false; 
      
      // Pillar 2: Validation Blueprint on Create
      allow create: if isOwner(userId) && isValidUser(incoming())
        && isValidId(userId)
        && incoming().keys().hasAll(['uid', 'balance', 'createdAt']);
      
      // Tiered Identity: Allowing owner to update balance for claimed orders
      allow update: if isOwner(userId) && incoming().diff(resource.data).affectedKeys().hasOnly(['balance', 'updatedAt']);

      // Subcollection: Transactions
      match /transactions/{txId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
      }
    }

    // Orders Collection
    match /orders/{orderId} {
      allow read, write: if true;
    }
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
